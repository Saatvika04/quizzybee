{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "api/**"
    ],
    "rewrites": [
      {
        "source": "/api/generateQuiz",
        "function": "generateQuiz"
      }
    ]
  }
}
